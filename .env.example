# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# Razorpay Configuration (Test Mode)
# Get these from https://dashboard.razorpay.com/settings/api-keys
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
EXPO_PUBLIC_RAZORPAY_KEY_SECRET=your_test_key_secret

# Razorpay Configuration (Production - Do NOT commit)
# Only use after testing is complete
# RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxx
# RAZORPAY_LIVE_KEY_SECRET=your_live_key_secret

# Expo Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000

# OTP Configuration
EXPO_PUBLIC_OTP_SECRET=your-secret-key

# Feature Flags
EXPO_PUBLIC_ENABLE_PAYMENTS=true
EXPO_PUBLIC_ENABLE_RAZORPAY=true
