{
  "expo": {
    "owner": "pratham886",
    "name": "My Society Details",
    "slug": "my-society-details",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/msd-logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "mysocietydetails",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.MySocietyApp",
      "buildNumber": "1.0.9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/msd-logo.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.MySocietyApp",
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 9,
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/msd-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F1F2F4"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/msd-logo.png",
          "color": "#4361EE"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f7b560ee-e144-48b9-bf3c-12ac00aec9cc"
      }
    }
  }
}
