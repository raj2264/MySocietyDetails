{
  "expo": {
    "owner": "pratham886",
    "name": "My Society Details Closed Testing",
    "slug": "my-society-details",
    "version": "1.0.7",
    "cli": {
      "appVersionSource": "local"
    },
    "orientation": "portrait",
    "icon": "./assets/images/msd-logo.jpeg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "mysocietydetails",
    "splash": {
      "image": "./assets/images/msd-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/msd-logo.jpeg",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.MySocietyApp",
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 7,
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/msd-logo.jpeg",
          "color": "#4361EE"
        }
      ]
    ],
    "entryPoint": "./index.js",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f7b560ee-e144-48b9-bf3c-12ac00aec9cc"
      }
    }
  }
}
